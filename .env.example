# ─── Domain ───────────────────────────────────────────────
MAIL_DOMAIN=mail.example.com

# ─── Auth: Google OAuth (optional — enable Google SSO) ───
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# ─── Auth: Microsoft Entra ID (optional — enable MS SSO) ─
MICROSOFT_CLIENT_ID=
MICROSOFT_CLIENT_SECRET=
MICROSOFT_TENANT_ID=common

# ─── Outbound: pick ONE (auto-detected by which key is set) ─
# Option 1: Resend (free: 3k/mo)
RESEND_API_KEY=

# Option 2: Postmark (free: 100/mo)
POSTMARK_API_KEY=

# Option 3: Cloudflare Email Service (requires Workers Paid plan)
# No env var needed — uses native binding, configured in wrangler.toml

# ─── Session ──────────────────────────────────────────────
SESSION_SECRET=generate-a-random-64-char-string-here

# ─── App ──────────────────────────────────────────────────
APP_NAME=cmail
APP_URL=https://mail.example.com

# ─── Bootstrap (first-run admin) ──────────────────────────
# On first sign-in by this email, the user is auto-provisioned as a manager
# AND a personal mailbox is created for them. Leave empty after bootstrap.
BOOTSTRAP_ADMIN_EMAIL=
